{
  "name": "@expgov/cli",
  "version": "1.0.0",
  "description": "Portable export-governance CLI for TypeScript SDK barrels.",
  "homepage": "https://expgov.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zamdevio/expgov.git"
  },
  "bugs": {
    "url": "https://github.com/zamdevio/expgov/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "expgov": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "typescript",
    "sdk",
    "exports",
    "barrel",
    "semver",
    "governance",
    "cli",
    "developer-tools",
    "expgov"
  ],
  "scripts": {
    "build": "pnpm core:build && pnpm cli:build",
    "postbuild": "chmod +x dist/cli.js",
    "typecheck": "pnpm core:typecheck && pnpm core:build && pnpm cli:typecheck",
    "test": "vitest run",
    "test:summary": "pnpm test 2>&1 | grep -E 'Test Files|Tests|Start at|Duration'",
    "knip": "knip",
    "madge:circular": "node scripts/madge/run.mjs circular",
    "madge:orphans": "node scripts/madge/run.mjs orphans",
    "madge:leaves": "node scripts/madge/run.mjs leaves",
    "core:build": "pnpm --filter @expgov/core build",
    "core:typecheck": "pnpm --filter @expgov/core typecheck",
    "cli:build": "tsup",
    "cli:typecheck": "tsc -p packages/cli/tsconfig.json --noEmit",
    "cli:dev": "tsx --tsconfig tsconfig.json packages/cli/bin/cli.ts",
    "docs:sync": "pnpm --filter @expgov/docs sync",
    "docs:sync:verify": "pnpm --filter @expgov/docs sync:verify",
    "docs:dev": "pnpm --filter @expgov/docs dev",
    "docs:build": "pnpm --filter @expgov/docs build",
    "docs:deploy": "pnpm --filter @expgov/docs run deploy",
    "docs:typecheck": "pnpm --filter @expgov/docs typecheck",
    "prepack": "EXPGOV_PUBLISH=1 pnpm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "jiti": "^2.4.2",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@expgov/core": "workspace:*",
    "@types/node": "^22.10.0",
    "knip": "^6.12.0",
    "madge": "^8.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "vitest": "^3.2.0"
  }
}
