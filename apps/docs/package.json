{
  "name": "@expgov/docs",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Documentation site (VitePress). Content is synced from repository docs/.",
  "scripts": {
    "sync": "node scripts/sync.js",
    "sync:verify": "node scripts/verify.mjs",
    "sync:watch": "node scripts/sync.js --watch",
    "dev": "node scripts/dev.mjs",
    "dev:no-watch": "pnpm run sync && vitepress dev . --host 0.0.0.0 --port 8284",
    "build": "pnpm run sync && vitepress build .",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm run build && wrangler pages deploy .vitepress/dist --project-name=expgov"
  },
  "dependencies": {
    "vitepress": "2.0.0-alpha.17"
  },
  "devDependencies": {
    "vue": "^3.5.27",
    "wrangler": "^4.54.0"
  }
}
