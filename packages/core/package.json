{
  "name": "@expgov/core",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "description": "Export governance engine — barrel inventory, diff, validate, trend, timeline, and graph.",
  "homepage": "https://expgov.pages.dev/sdk/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zamdevio/expgov.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/zamdevio/expgov/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "EXPGOV_PUBLISH=1 pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./advanced": {
      "types": "./dist/advanced/index.d.ts",
      "import": "./dist/advanced/index.js",
      "default": "./dist/advanced/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js",
      "default": "./dist/internal/index.js"
    }
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "jiti": "^2.4.2",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
