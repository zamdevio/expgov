{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@expgov/core": ["./packages/core/src/index.ts"],
      "@expgov/core/advanced": ["./packages/core/src/advanced/index.ts"],
      "@expgov/core/internal": ["./packages/core/src/internal/index.ts"],
      "@expgov/cli/core": ["./dist/core.d.ts", "./packages/core/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "tsup.config.ts", "expgov.config.ts"]
}
